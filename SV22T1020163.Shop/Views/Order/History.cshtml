@model PagedResult<OrderViewInfo>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    int currentStatus = ViewBag.CurrentStatus;
}

@functions {
    string GetStatusPillClass(OrderStatusEnum status)
    {
        return status switch
        {
            OrderStatusEnum.New => "order-status-pill--new",
            OrderStatusEnum.Accepted => "order-status-pill--accepted",
            OrderStatusEnum.Shipping => "order-status-pill--shipping",
            OrderStatusEnum.Completed => "order-status-pill--completed",
            OrderStatusEnum.Rejected => "order-status-pill--rejected",
            OrderStatusEnum.Cancelled => "order-status-pill--cancelled",
            _ => "order-status-pill--muted"
        };
    }
}

<div class="container py-4 order-history-page">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Đơn hàng của tôi</li>
        </ol>
    </nav>

    <header class="order-history-hero reveal mb-4">
        <h1 class="h4 fw-bold mb-1"><i class="bi bi-bag-check me-2 text-primary"></i>Đơn hàng của tôi</h1>
        <p class="text-muted mb-0 small">Theo dõi trạng thái và chi tiết từng đơn.</p>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- Status Tabs -->
    <ul class="nav nav-pills nav-pills-order mb-4 flex-wrap">
        @{
            var statuses = new (int val, string label)[] {
                (0, "Tất cả"), (1, "Mới"), (2, "Đã duyệt"), (3, "Đang giao"), (4, "Hoàn tất"), (-1, "Đã hủy"), (-2, "Bị từ chối")
            };
        }
        @foreach (var s in statuses)
        {
            <li class="nav-item">
                <a class="nav-link @(currentStatus == s.val ? "active" : "")"
                   asp-action="History" asp-route-status="@s.val">@s.label</a>
            </li>
        }
    </ul>

    @if (Model.DataItems.Any())
    {
        @foreach (var order in Model.DataItems)
        {
            <div class="order-card reveal">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <strong class="text-dark">Đơn hàng #@order.OrderID</strong>
                        <span class="order-status-pill order-status-pill--sm @GetStatusPillClass(order.Status) ms-2 align-middle">@order.Status.GetDescription()</span>
                    </div>
                    <div class="text-muted small">@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="text-muted small mt-1">
                    <i class="bi bi-geo-alt me-1"></i>@order.DeliveryProvince - @order.DeliveryAddress
                </div>
                <div class="mt-2 d-flex justify-content-between align-items-center">
                    <a asp-action="Detail" asp-route-id="@order.OrderID" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-eye me-1"></i>Chi tiết
                    </a>
                </div>
            </div>
        }

        @if (Model.PageCount > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @foreach (var p in Model.GetDisplayPages())
                    {
                        if (p.IsEllipsis)
                        {
                            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                        }
                        else
                        {
                            <li class="page-item @(p.IsCurrent ? "active" : "")">
                                <a class="page-link" asp-action="History" asp-route-status="@currentStatus" asp-route-page="@p.Page">@p.Page</a>
                            </li>
                        }
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="empty-state text-center">
            <div class="empty-state-icon"><i class="bi bi-inbox"></i></div>
            <p class="text-muted mb-3">Chưa có đơn hàng nào trong mục này.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Mua sắm ngay</a>
        </div>
    }
</div>
