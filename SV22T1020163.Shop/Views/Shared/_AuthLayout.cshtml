<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")SmartMini</title>
    <link rel="icon" type="image/svg+xml" href="~/anh_chung/logo-smartmini.svg" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,600;0,7..72,700;1,7..72,400&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-shell">
    <div class="auth-shell__mesh" aria-hidden="true"></div>
    <div class="auth-shell__main">
        <a class="auth-shell__brand d-inline-flex align-items-center gap-2 justify-content-center" asp-controller="Home" asp-action="Index" title="Về trang chủ SmartMini">
            <img src="~/anh_chung/logo-smartmini.svg" alt="SmartMini" width="240" height="40" asp-append-version="true" />
        </a>
        @RenderBody()
        <nav class="auth-shell__footer text-center mt-4" aria-label="Điều hướng">
            <a asp-controller="Home" asp-action="Index" class="auth-shell__home-link">
                <i class="bi bi-arrow-left-short" aria-hidden="true"></i> Về trang chủ
            </a>
        </nav>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
