@model Product
@{
    ViewData["Title"] = Model.ProductName;
    var photos = ViewBag.Photos as List<ProductPhoto> ?? new List<ProductPhoto>();
    var attrs = ViewBag.Attributes as List<ProductAttribute> ?? new List<ProductAttribute>();
    var related = ViewBag.RelatedProducts as List<Product> ?? new List<Product>();
    var mainImg = string.IsNullOrEmpty(Model.Photo) ? "/anh_chung/products/noproduct.svg" : "/anh_chung/products/" + Model.Photo;
}

<div class="container py-4 product-detail-page book-detail-layout">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
            <li class="breadcrumb-item active">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="detail-page-card mb-4 reveal product-detail-main">
        <div class="row g-4 g-lg-5 align-items-start">
            <!-- Gallery -->
            <div class="col-lg-6 col-xl-5">
                <div class="product-detail-gallery text-center mb-3 rounded-3 p-3 book-cover-stage">
                    <img id="mainImage" src="@mainImg" class="img-fluid detail-main-image" style="max-height:420px;object-fit:contain;" alt="@Model.ProductName" />
                </div>
                @if (photos.Any())
                {
                    <div class="d-flex gap-2 justify-content-center detail-gallery flex-wrap">
                        <img src="@mainImg" class="img-thumbnail" style="width:60px;height:60px;object-fit:contain;cursor:pointer;"
                             onclick="document.getElementById('mainImage').src=this.src" />
                        @foreach (var photo in photos.Where(p => !p.IsHidden))
                        {
                            var photoSrc = string.IsNullOrEmpty(photo.Photo) ? "/anh_chung/products/noproduct.svg" : "/anh_chung/products/" + photo.Photo;
                            <img src="@photoSrc" class="img-thumbnail" style="width:60px;height:60px;object-fit:contain;cursor:pointer;"
                                 onclick="document.getElementById('mainImage').src=this.src" />
                        }
                    </div>
                }
            </div>

            <!-- Info -->
            <div class="col-lg-6 col-xl-7">
                <div class="product-detail-sticky">
                <h1 class="fw-bold fs-3 mb-3">@Model.ProductName</h1>

                <div class="detail-price detail-price--hero mb-3">@Model.Price.ToString("N0") đ</div>

                <table class="table table-sm mb-3" style="max-width:300px;">
                    <tr><td class="text-muted">Đơn vị tính</td><td class="fw-bold">@Model.Unit</td></tr>
                    <tr>
                        <td class="text-muted">Trạng thái</td>
                        <td>
                            @if (Model.IsSelling)
                            {
                                <span class="badge bg-success">Còn hàng</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Hết hàng</span>
                            }
                        </td>
                    </tr>
                </table>

                @if (Model.IsSelling)
                {
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex align-items-center gap-3 mb-3">
                        <input type="hidden" name="productId" value="@Model.ProductID" />
                        <div class="quantity-control">
                            <label class="form-label mb-0 me-2">Số lượng:</label>
                            <input type="number" name="quantity" value="1" min="1" class="form-control" style="width:80px;" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ hàng
                        </button>
                    </form>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ProductDescription))
                {
                    <div class="mt-3">
                        <h6 class="fw-bold">Mô tả sản phẩm</h6>
                        <p class="text-muted">@Model.ProductDescription</p>
                    </div>
                }
                </div>
            </div>
        </div>
    </div>

    <!-- Attributes -->
    @if (attrs.Any())
    {
        <div class="detail-page-card mb-4 reveal">
            <h4 class="fw-bold mb-3"><i class="bi bi-list-check me-2"></i>Thông số kỹ thuật</h4>
            <table class="table table-striped mb-0">
                @foreach (var a in attrs.OrderBy(x => x.DisplayOrder))
                {
                    <tr>
                        <td class="fw-bold" style="width:200px;">@a.AttributeName</td>
                        <td>@a.AttributeValue</td>
                    </tr>
                }
            </table>
        </div>
    }

    <!-- Related Products -->
    @if (related.Any())
    {
        <div class="mb-4">
            <h4 class="section-title">Sản phẩm liên quan</h4>
            <div class="row g-3 reveal-stagger">
                @foreach (var p in related)
                {
                    <div class="col-6 col-md-3">
                        <div class="product-card reveal h-100">
                            <a asp-action="Detail" asp-route-id="@p.ProductID">
                                <div class="card-img-wrap">
                                    <img src="@(string.IsNullOrEmpty(p.Photo) ? "/anh_chung/products/noproduct.svg" : "/anh_chung/products/" + p.Photo)"
                                         alt="@p.ProductName" />
                                </div>
                            </a>
                            <div class="card-body">
                                <a class="product-name" asp-action="Detail" asp-route-id="@p.ProductID">@p.ProductName</a>
                                <div class="product-price">@p.Price.ToString("N0") đ</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
