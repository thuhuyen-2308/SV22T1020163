@model Customer
@{
    ViewData["Title"] = "Thông tin tài khoản";
    var provinces = ViewBag.Provinces as List<SV22T1020163.Models.DataDictionary.Province> ?? new List<SV22T1020163.Models.DataDictionary.Province>();
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Thông tin tài khoản</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-3 mb-4">
            @await Html.PartialAsync("_AccountSidebar")
        </div>
        <div class="col-lg-9">
            <div class="static-page-card reveal">
                <h4 class="fw-bold mb-4"><i class="bi bi-person me-2"></i>Thông tin cá nhân</h4>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
                }

                <form method="post" asp-action="Profile">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Tên khách hàng <span class="text-danger">*</span></label>
                            <input type="text" name="CustomerName" class="form-control" value="@Model.CustomerName" required />
                            <span class="text-danger small">@Html.ValidationMessage("CustomerName")</span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tên giao dịch</label>
                            <input type="text" name="ContactName" class="form-control" value="@Model.ContactName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control" value="@Model.Email" required />
                            <span class="text-danger small">@Html.ValidationMessage("Email")</span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Điện thoại</label>
                            <input type="text" name="Phone" class="form-control" value="@Model.Phone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tỉnh / Thành phố</label>
                            <select name="Province" class="form-select">
                                <option value="">-- Chọn tỉnh/thành --</option>
                                @foreach (var p in provinces)
                                {
                                    if (p.ProvinceName == Model.Province)
                                    {
                                        <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                    }
                                    else
                                    {
                                        <option value="@p.ProvinceName">@p.ProvinceName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Địa chỉ</label>
                            <input type="text" name="Address" class="form-control" value="@Model.Address" />
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-2"></i>Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
