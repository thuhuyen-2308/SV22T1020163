@{
    ViewBag.Title = "Phân quyền nhân viên";
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
    var currentRoles = ViewBag.CurrentRoles as List<string> ?? new List<string>();
}
@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i> Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">Phân quyền cho nhân viên</h5>
            </div>

            <div class="card-body">
                @* Lưu ý: Thêm action và controller tương ứng *@
                <form id="formChangeRole" action="~/Employee/ChangeRole" method="post">
                    @* Hidden field để gửi ID nhân viên về server *@
                    <input type="hidden" name="id" value="@Model.EmployeeID" />

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">Thông tin nhân viên</legend>
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">Danh sách quyền</legend>
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width:60px;" class="text-center">Chọn</th>
                                        <th>Tên quyền</th>
                                        <th>Mô tả quyền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var roleName in allRoles)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox"
                                                   name="roleNames"
                                                   value="@roleName"
                                                   @(currentRoles.Contains(roleName) ? "checked" : "") />
                                        </td>
                                        <td><strong>@roleName</strong></td>
                                        <td>Quyền sử dụng chức năng @roleName trong hệ thống</td>
                                    </tr>
                                }
                            </tbody>
                            </table>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>