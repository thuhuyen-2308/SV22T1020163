@model SV22T1020163.Models.Common.PaginationSearchInput
@{
    ViewBag.Title = "Quản lý Nhân viên";
}
@section PageToolBar {
    <a href="~/Employee/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Employee/Search" data-target="searchResult">
            <div class="input-group">
                <input id="searchValue" name="searchValue" type="text"
                       class="form-control"
                       placeholder="Nhập tên nhân viên" autofocus
                       value="@Model.SearchValue" />
                <button type="submit" class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
    <!-- Search Results will be loaded here -->
</div>

@section Scripts {
    <script>
        function doSearch(page) {
            paginationSearch(null, document.getElementById("formSearch"), page);
        }

        document.addEventListener("DOMContentLoaded", function () {
            doSearch(@Model.Page);

            const formSearch = document.getElementById("formSearch");
            if (formSearch) {
                formSearch.addEventListener("submit", function (e) {
                    paginationSearch(e, this, 1);
                });
            }
        });
    </script>
}
