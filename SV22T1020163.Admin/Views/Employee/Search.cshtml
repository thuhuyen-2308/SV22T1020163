@model SV22T1020163.Models.Common.PagedResult<SV22T1020163.Models.HR.Employee>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên. 
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:100px;">Ảnh</th>
                    <th>Họ và tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? "/anh_chung/employees/nophoto.png" : "/anh_chung/employees/" + item.Photo)" 
                                 class="rounded" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.FullName" />
                        </td>
                        <td>@item.FullName</td>
                        <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td class="text-center">
                            @if (item.IsWorking == true)
                            {
                                <span class="badge bg-success">Đang làm việc</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã nghỉ việc</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info" title="Phân quyền">
                                <i class="bi bi-shield-lock"></i>
                            </a>

                            <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning" title="Đổi mật khẩu">
                                <i class="bi bi-key"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        @if (Model.PageCount > 1)
        {
            <nav>
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page - 1))">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @foreach (var p in Model.GetDisplayPages())
                    {
                        if (p.Page == 0)
                        {
                            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                        }
                        else if (p.IsCurrent)
                        {
                            <li class="page-item active"><span class="page-link">@p.Page</span></li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:;" onclick="doSearch(@p.Page)">@p.Page</a>
                            </li>
                        }
                    }
                    <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page + 1))">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
