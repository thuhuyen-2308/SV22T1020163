@model SV22T1020163.Models.HR.Employee
@{
    var isCreate = (Model.EmployeeID == 0);
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    @(isCreate ? "Thêm mới nhân viên" : "Cập nhật nhân viên")
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="@(isCreate ? Url.Action("Create", "Employee") : Url.Action("Edit", "Employee"))">

                    <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />
                    @* Giữ lại ảnh cũ để không bị null trong DB *@
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    @* Hiển thị tổng hợp các lỗi ở đầu Form (nếu có) *@
                    <div class="mb-3">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Họ và tên</label>
                        <div class="col-sm-5">
                            <input type="text" name="FullName" class="form-control"
                                   value="@Model.FullName" placeholder="Nhập họ và tên" autofocus />
                            @Html.ValidationMessage(nameof(Model.FullName), "", new { @class = "text-danger" })
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input type="text" name="BirthDate" class="form-control date-picker"
                                   value="@(Model.BirthDate?.ToString("dd/MM/yyyy"))" />
                            @Html.ValidationMessage(nameof(Model.BirthDate), "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea name="Address" class="form-control" rows="3"
                                      placeholder="Nhập địa chỉ">@Model.Address</textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-3">
                            <input type="tel" name="Phone" class="form-control"
                                   value="@Model.Phone" placeholder="Nhập số điện thoại" />
                        </div>
                        <label class="col-sm-1 col-form-label text-end">Email</label>
                        <div class="col-sm-5">
                            <input type="email" name="Email" class="form-control"
                                   value="@Model.Email" placeholder="Nhập email" />
                            @Html.ValidationMessage(nameof(Model.Email), "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox"
                                       name="IsWorking" id="IsWorking" value="true"
                                @(Model.IsWorking == true ? "checked" : "") />
                                <label class="form-check-label" for="IsWorking">
                                    Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>