@model SV22T1020163.Models.Partner.Shipper
@{
    ViewData["Title"] = "Xóa người giao hàng";
    var isUsed = ViewBag.IsUsed as bool? == true;
}

@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger" @(isUsed ? "disabled" : null)>
        <i class="bi bi-trash me-1"></i>
        Xóa
    </button>

    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-octagon-fill me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" asp-action="Delete" asp-route-id="@Model.ShipperID" method="post">
                    <input type="hidden" name="confirm" value="yes" />

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa người giao hàng sau không?
                    </div>

                    @if (isUsed)
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-lock me-2"></i>
                            Người giao hàng này đang được sử dụng và không thể xóa.
                        </div>
                    }

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Tên người giao hàng</dt>
                        <dd class="col-sm-8">@Model.ShipperName</dd>

                        <dt class="col-sm-4">Điện thoại</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>
