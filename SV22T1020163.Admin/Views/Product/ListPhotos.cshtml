@model List<SV22T1020163.Models.Catalog.ProductPhoto>
@{
    Layout = null;
    int productId = 0;
    if (Model != null && Model.Count > 0)
        productId = Model[0].ProductID;
    else if (ViewBag.ProductID != null)
        productId = (int)ViewBag.ProductID;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@productId">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var photo in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(photo.Photo))
                                        {
                                            <img src="~/anh_chung/products/@photo.Photo"
                                                 class="img-thumbnail"
                                                 style="max-height:80px;" />
                                        }
                                        else
                                        {
                                            <img src="~/anh_chung/products/nophoto.png"
                                                 class="img-thumbnail"
                                                 style="max-height:80px;" />
                                        }
                                    </td>
                                    <td>@photo.Description</td>
                                    <td class="text-center">@photo.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (photo.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@productId?photoId=@photo.PhotoID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@productId?photoId=@photo.PhotoID">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-3">Chưa có ảnh nào</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
