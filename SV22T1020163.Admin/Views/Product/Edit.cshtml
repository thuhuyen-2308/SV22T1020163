@model SV22T1020163.Models.Catalog.Product

@{
    var isCreate = (Model.ProductID == 0);
    var categories = ViewBag.Categories as SV22T1020163.Models.Common.PagedResult<SV22T1020163.Models.Catalog.Category>;
    var suppliers = ViewBag.Suppliers as SV22T1020163.Models.Common.PagedResult<SV22T1020163.Models.Partner.Supplier>;
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    @(isCreate ? "Thêm mới mặt hàng" : "Cập nhật mặt hàng")
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post"
                      asp-action="@(isCreate ? "Create" : "Edit")"
                      enctype="multipart/form-data">

                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="ProductName"
                                   class="form-control"
                                   value="@Model.ProductName"
                                   placeholder="Nhập tên mặt hàng" autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select name="CategoryID" class="form-select">
                                <option value="">-- Chọn loại hàng --</option>
                                @if (categories != null)
                                {
                                    foreach (var c in categories.DataItems)
                                    {
                                        <option value="@c.CategoryID"
                                                selected="@(Model.CategoryID == c.CategoryID)">
                                            @c.CategoryName
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select name="SupplierID" class="form-select">
                                <option value="">-- Chọn nhà cung cấp --</option>
                                @if (suppliers != null)
                                {
                                    foreach (var s in suppliers.DataItems)
                                    {
                                        <option value="@s.SupplierID"
                                                selected="@(Model.SupplierID == s.SupplierID)">
                                            @s.SupplierName
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text"
                                   name="Unit"
                                   class="form-control"
                                   value="@Model.Unit"
                                   placeholder="cái, hộp, kg..." />
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="text"
                                   name="Price"
                                   class="form-control money-input"
                                   value="@Model.Price.ToString("0")"
                                   placeholder="Giá bán" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsSelling"
                                       id="IsSelling"
                                       value="true"
                                       @(Model.IsSelling ? "checked" : "") />
                                <label class="form-check-label" for="IsSelling">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />
                            <div class="mt-2">
                                @if (!string.IsNullOrEmpty(Model.Photo))
                                {
                                    <img id="imgPreview"
                                         src="~/anh_chung/products/@Model.Photo"
                                         class="img-thumbnail"
                                         style="max-height: 160px;" />
                                }
                                else
                                {
                                    <img id="imgPreview"
                                         src="~/anh_chung/products/nophoto.png"
                                         class="img-thumbnail"
                                         style="max-height: 160px;" />
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea name="ProductDescription"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Nhập mô tả mặt hàng">@Model.ProductDescription</textarea>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@if (!isCreate)
{
    await Html.RenderPartialAsync("ListPhotos", ViewBag.Photos as List<SV22T1020163.Models.Catalog.ProductPhoto>);
    await Html.RenderPartialAsync("ListAttributes", ViewBag.Attributes as List<SV22T1020163.Models.Catalog.ProductAttribute>);
}
