@model SV22T1020163.Models.Catalog.ProductSearchInput
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}
@section PageToolBar {
    @if (User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.Manager))
    {
        <a href="~/Product/Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Bổ sung
        </a>
    }
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Product/Search" data-target="searchResult">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" name="@nameof(Model.CategoryID)">
                        <option value="0">-- Tất cả --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var item in ViewBag.Categories.DataItems)
                            {
                                if (item.CategoryID == Model.CategoryID)
                                {
                                    <option value="@item.CategoryID" selected>@item.CategoryName</option>
                                }
                                else
                                {
                                    <option value="@item.CategoryID">@item.CategoryName</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" name="@nameof(Model.SupplierID)">
                        <option value="0">-- Tất cả --</option>
                        @if (ViewBag.Suppliers != null)
                        {
                            foreach (var item in ViewBag.Suppliers.DataItems)
                            {
                                if (item.SupplierID == Model.SupplierID)
                                {
                                    <option value="@item.SupplierID" selected>@item.SupplierName</option>
                                }
                                else
                                {
                                    <option value="@item.SupplierID">@item.SupplierName</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text"
                               name="@nameof(Model.MinPrice)" 
                               class="form-control"
                               placeholder="Từ" value="@(Model.MinPrice > 0 ? Model.MinPrice.ToString("0") : "")" />
                        <span class="input-group-text">-</span>
                        <input type="text"
                               name="@nameof(Model.MaxPrice)"
                               class="form-control"
                               placeholder="Đến" value="@(Model.MaxPrice > 0 ? Model.MaxPrice.ToString("0") : "")" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input id="searchValue" name="SearchValue" type="text"
                               class="form-control"
                               placeholder="Tên mặt hàng..." autofocus
                               value="@Model.SearchValue" />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
    <!-- Search Results will be loaded here -->
</div>

@section Scripts {
    <script>
        function doSearch(page) {
            paginationSearch(null, document.getElementById("formSearch"), page);
        }

        document.addEventListener("DOMContentLoaded", function () {
            doSearch(@Model.Page);

            // const formSearch = document.getElementById("formSearch");
            // if (formSearch) {
            //     formSearch.addEventListener("submit", function (e) {
            //         paginationSearch(e, this, 1);
            //     });
            // }
        });
    </script>
}
