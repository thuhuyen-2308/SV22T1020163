@model SV22T1020163.Models.Catalog.ProductPhoto
@{
    var isCreate = (Model.PhotoID == 0);
    int productId = ViewBag.ProductID ?? Model.ProductID;
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        @(isCreate ? "Tải lên" : "Lưu ảnh")
    </button>

    <a href="~/Product/Edit/@productId#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0">@(isCreate ? "Thêm ảnh mặt hàng" : "Cập nhật ảnh mặt hàng")</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post"
                      asp-action="@(isCreate ? "CreatePhoto" : "EditPhoto")"
                      enctype="multipart/form-data">

                    @* 1. CỰC KỲ QUAN TRỌNG: Phải có các trường ẩn này để gửi về Controller *@
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="PhotoID" value="@Model.PhotoID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    @* Hiển thị lỗi tổng quát nếu có *@
                    <div class="text-danger mb-2">
                        @Html.ValidationSummary(true)
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Ảnh</label>
                        <div class="col-sm-9">
                            @* 2. Tên name="Photo" phải trùng với tham số IFormFile trong Controller *@
                            <input type="file"
                                   name="Photo"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            @Html.ValidationMessage("Photo", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            <img id="imgPreview"
                                 src="~/anh_chung/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail"
                                 style="max-height:200px;" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả</label>
                        <div class="col-sm-9">
                            <input type="text" name="Description"
                                   value="@Model.Description"
                                   class="form-control" />
                            @* 3. HIỂN THỊ LỖI: Để tránh sập trang khi để trống mô tả *@
                            @Html.ValidationMessage("Description", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="@Model.DisplayOrder"
                                   min="1" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsHidden"
                                       id="IsHidden"
                                       value="true"
                                @(Model.IsHidden ? "checked" : "") />
                                <label class="form-check-label" for="IsHidden">
                                    Ẩn ảnh
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>