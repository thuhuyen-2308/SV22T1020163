@model SV22T1020163.Models.Partner.Customer
@{
    // Giả sử logic kiểm tra Create/Edit tương tự Employee
    var isCreate = (Model.CustomerID == 0);
}

@section PageToolBar {
    <button type="submit" form="formCustomer" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="card card-primary card-outline mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-person-plus me-2"></i>
            @(isCreate ? "Thêm khách hàng mới" : "Cập nhật khách hàng")
        </h3>
    </div>
    
    @* Gán ID cho form để nút bấm từ ToolBar có thể Submit được thông qua thuộc tính form="formCustomer" *@
    <form id="formCustomer" asp-action="@(isCreate ? "Create" : "Edit")" method="post">
        <input type="hidden" asp-for="CustomerID" />

        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="CustomerName" class="form-label">Tên khách hàng: <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" asp-for="CustomerName" autofocus>
                            @Html.ValidationMessageFor(m => m.CustomerName, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="ContactName" class="form-label">Tên liên hệ: <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="ContactName">
                                @Html.ValidationMessageFor(m => m.ContactName, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Phone" class="form-label">Điện thoại:</label>
                                <input type="tel" class="form-control" asp-for="Phone">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">Email: <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control" asp-for="Email">
                                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="Province" class="form-label">Tỉnh/Thành phố: <span class="text-danger">*</span></label>
                                        <select class="form-select" asp-for="Province">
                                            <option value="">-- Chọn tỉnh/thành --</option>
                                            @if (ViewBag.Provinces != null)
                                            {
                                                foreach (var item in ViewBag.Provinces)
                                                {
                                                    <option value="@item.ProvinceName">@item.ProvinceName</option>
                                                }
                                            }
                                        </select>
                                        @Html.ValidationMessageFor(m => m.Province, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="Password" class="form-label">Mật khẩu:</label>
                                        <input type="password" class="form-control" asp-for="Password">
                                            @* Thêm nhắc nhở nếu cần thiết *@
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Address" class="form-label">Địa chỉ:</label>
                                    <textarea class="form-control" asp-for="Address" rows="2" placeholder="Nhập địa chỉ chi tiết"></textarea>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" asp-for="IsLocked">
                                            <label class="form-check-label" asp-for="IsLocked">
                                                Khóa tài khoản khách hàng
                                            </label>
                                        </div>
                                    </div>

                                    @* Vùng hiển thị lỗi tổng quát *@
                                    @if (!ViewData.ModelState.IsValid)
                                    {
                                        <div class="alert alert-danger alert-dismissible fade show">
                                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                            @Html.ValidationSummary(true)
                                        </div>
                                    }
                                </div>
        
                                @* Card footer giờ có thể để trống hoặc xóa bỏ nếu không dùng *@
                            </form>
                        </div>