@model SV22T1020163.Models.Common.PagedResult<SV22T1020163.Models.Sales.OrderViewInfo>
@using SV22T1020163.Models.Sales
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng. 
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Mã ĐH</th>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems != null && Model.DataItems.Count > 0)
                {
                    foreach (var order in Model.DataItems)
                    {
                        string badgeClass = order.Status switch
                        {
                            OrderStatusEnum.New => "bg-warning text-dark",
                            OrderStatusEnum.Accepted => "bg-info",
                            OrderStatusEnum.Shipping => "bg-primary",
                            OrderStatusEnum.Completed => "bg-success",
                            OrderStatusEnum.Cancelled => "bg-secondary",
                            OrderStatusEnum.Rejected => "bg-danger",
                            _ => "bg-secondary"
                        };
                        string statusText = order.Status switch
                        {
                            OrderStatusEnum.New => "Chờ duyệt",
                            OrderStatusEnum.Accepted => "Đã duyệt",
                            OrderStatusEnum.Shipping => "Đang giao",
                            OrderStatusEnum.Completed => "Hoàn tất",
                            OrderStatusEnum.Cancelled => "Đã hủy",
                            OrderStatusEnum.Rejected => "Từ chối",
                            _ => "Không rõ"
                        };
                        <tr>
                            <td class="text-center">@order.OrderID</td>
                            <td>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.CustomerName</td>
                            <td>@order.CustomerPhone</td>
                            <td>@(order.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                            <td>@order.EmployeeName</td>
                            <td class="text-center">
                                <span class="badge @badgeClass">@statusText</span>
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Order/Detail/@order.OrderID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-3">Không tìm thấy đơn hàng nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        @if (Model.PageCount > 1)
        {
            <nav>
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @foreach (var p in Model.GetDisplayPages())
                    {
                        if (p.Page == 0)
                        {
                            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                        }
                        else if (p.IsCurrent)
                        {
                            <li class="page-item active"><span class="page-link">@p.Page</span></li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                            </li>
                        }
                    }
                    <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                        <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
