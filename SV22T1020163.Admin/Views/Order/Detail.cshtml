@model SV22T1020163.Models.Sales.OrderViewInfo
@using SV22T1020163.Models.Sales
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var details = ViewBag.Details as List<OrderDetailViewInfo> ?? new List<OrderDetailViewInfo>();
    decimal totalAmount = details.Sum(d => d.TotalPrice);

    bool canAccept = Model.Status == OrderStatusEnum.New;
    bool canShip = Model.Status == OrderStatusEnum.Accepted;
    bool canFinish = Model.Status == OrderStatusEnum.Shipping;
    bool canCancel = Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Accepted;
    bool canReject = Model.Status == OrderStatusEnum.New;
    bool canDelete = Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Cancelled || Model.Status == OrderStatusEnum.Rejected;
    bool canEditDetail = Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Accepted;

    string alertClass = Model.Status switch
    {
        OrderStatusEnum.New => "alert-warning",
        OrderStatusEnum.Accepted => "alert-info",
        OrderStatusEnum.Shipping => "alert-primary",
        OrderStatusEnum.Completed => "alert-success",
        OrderStatusEnum.Cancelled => "alert-secondary",
        OrderStatusEnum.Rejected => "alert-danger",
        _ => "alert-secondary"
    };
}

@section PageToolBar {
    @if (canAccept || canShip || canFinish || canCancel || canReject)
    {
        <div class="btn-group">
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                @if (canAccept)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
                }
                @if (canShip)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
                }
                @if (canFinish)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
                }
                @if (canCancel || canReject)
                {
                    <li><hr class="dropdown-divider"></li>
                }
                @if (canCancel)
                {
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
                }
                @if (canReject)
                {
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a></li>
                }
            </ul>
        </div>
    }

    @if (canDelete)
    {
        <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i> Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="alert @alertClass d-flex align-items-center mb-3">
    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái:</strong> @Model.Status.GetDescription()
        @if (Model.FinishedTime.HasValue)
        {
            <span> - @Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</span>
        }
    </div>
</div>

<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-receipt me-2"></i>Thông tin đơn hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@Model.EmployeeName</div>
            <div class="col-md-3 fw-bold">Ngày duyệt</div>
            <div class="col-md-3">@(Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa duyệt")</div>
        </div>
    </div>
</div>

<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-person me-2"></i>Thông tin khách hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>
            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-3">@Model.CustomerEmail</div>
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.CustomerPhone</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-truck me-2"></i>Thông tin giao hàng</h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@(string.IsNullOrEmpty(Model.ShipperName) ? "Chưa chỉ định" : Model.ShipperName)</div>
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-3">@Model.DeliveryProvince</div>
            <div class="col-md-3 fw-bold">Ngày giao</div>
            <div class="col-md-3">@(Model.ShippedTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa giao")</div>
        </div>
    </div>
</div>

<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-box-seam me-2"></i>Danh sách mặt hàng</h5>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    @if (canEditDetail)
                    {
                        <th style="width:90px"></th>
                    }
                </tr>
            </thead>
            <tbody>
                @{ int stt = 0; }
                @foreach (var item in details)
                {
                    stt++;
                    <tr>
                        <td class="text-center">@stt</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                        @if (canEditDetail)
                        {
                            <td class="text-end text-nowrap">
                                <a href="~/Order/EditDetail/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" asp-action="DeleteDetail" asp-route-id="@Model.OrderID" asp-route-productId="@item.ProductID" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa mặt hàng này?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@totalAmount.ToString("N0")</th>
                    @if (canEditDetail)
                    {
                        <th></th>
                    }
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row { border-bottom: 1px dotted #646464; }
    </style>
}
