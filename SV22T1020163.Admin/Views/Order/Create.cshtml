@using SV22T1020163.Models.Common
@using SV22T1020163.Models.Partner
@using SV22T1020163.Models.DataDictionary
@{
    ViewBag.Title = "Lập đơn hàng";
    var customers = ViewBag.Customers as PagedResult<Customer>;
    var provinces = ViewBag.Provinces as List<Province>;
    var cartItems = ViewBag.CartItems as List<dynamic> ?? new List<dynamic>();
    decimal cartTotal = ViewBag.CartTotal ?? 0m;

    var selectedCustomerID = TempData["SelectedCustomerID"] as string ?? "0";
    var selectedProvince = TempData["SelectedProvince"] as string ?? "";
    var selectedAddress = TempData["SelectedAddress"] as string ?? "";
}

@if (!string.IsNullOrEmpty(TempData["Error"] as string))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>
            <div class="card-body">
                <div class="input-group mb-3">
                    <input class="form-control" id="productSearchValue"
                           placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                    <button class="btn btn-primary" onclick="searchProducts(1)">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
                <div id="productSearchResults">
                    <p class="text-muted text-center">Nhập từ khóa để tìm mặt hàng</p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-cart"></i>
                    Danh sách mặt hàng đã chọn
                    <span class="badge bg-primary ms-1">@cartItems.Count</span>
                </h5>
            </div>
            <div class="card-body">
                @if (cartItems.Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-cart-x" style="font-size: 2rem;"></i>
                        <p class="mt-2">Giỏ hàng trống. Vui lòng chọn mặt hàng cần bán.</p>
                    </div>
                }
                else
                {
                    <table class="table table-bordered table-hover align-middle mb-2">
                        <thead class="table-success">
                            <tr>
                                <th class="text-center" style="width:40px">#</th>
                                <th>Tên hàng</th>
                                <th class="text-center" style="width:70px">ĐVT</th>
                                <th class="text-center" style="width:70px">SL</th>
                                <th class="text-end" style="width:130px">Giá bán</th>
                                <th class="text-end" style="width:130px">Thành tiền</th>
                                <th style="width:60px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{int idx = 0;}
                            @foreach (var item in cartItems)
                            {
                                idx++;
                                <tr>
                                    <td class="text-center">@idx</td>
                                    <td>@item.ProductName</td>
                                    <td class="text-center">@item.Unit</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@(((decimal)item.SalePrice).ToString("N0"))</td>
                                    <td class="text-end">@(((decimal)item.TotalPrice).ToString("N0"))</td>
                                    <td class="text-center text-nowrap">
                                        <form method="post" asp-action="RemoveFromCart" style="display:inline">
                                            <input type="hidden" name="productID" value="@item.ProductID" />
                                            <button type="submit" class="btn btn-sm btn-danger" title="Xóa">
                                                <i class="bi bi-dash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="5" class="text-end">Tổng cộng:</th>
                                <th class="text-end text-primary">@cartTotal.ToString("N0")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                    <div class="text-end">
                        <form method="post" asp-action="ClearCart" style="display:inline"
                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa tất cả mặt hàng trong giỏ hàng?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Xóa giỏ hàng
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>

        <div class="card card-outline card-info mt-3">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-person"></i>
                    Thông tin khách hàng & nơi giao hàng
                </h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Create" id="formCreateOrder">
                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label">Khách hàng <span class="text-danger">*</span></label>
                        <div class="col-md-10">
                            <select class="form-select" name="customerID" id="customerID" required>
                                <option value="0">-- Chọn khách hàng --</option>
                                @if (customers?.DataItems != null)
                                {
                                    foreach (var c in customers.DataItems)
                                    {
                                        var cSelected = c.CustomerID.ToString() == selectedCustomerID;
                                        if (cSelected)
                                        {
                                            <option value="@c.CustomerID" selected="selected">@c.CustomerName - @c.ContactName</option>
                                        }
                                        else
                                        {
                                            <option value="@c.CustomerID">@c.CustomerName - @c.ContactName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label">Tỉnh/thành <span class="text-danger">*</span></label>
                        <div class="col-md-10">
                            <select class="form-select" name="deliveryProvince" id="deliveryProvince" required>
                                <option value="">-- Chọn Tỉnh/thành giao hàng --</option>
                                @if (provinces != null)
                                {
                                    foreach (var p in provinces)
                                    {
                                        var pSelected = p.ProvinceName == selectedProvince;
                                        if (pSelected)
                                        {
                                            <option value="@p.ProvinceName" selected="selected">@p.ProvinceName</option>
                                        }
                                        else
                                        {
                                            <option value="@p.ProvinceName">@p.ProvinceName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label">Địa chỉ <span class="text-danger">*</span></label>
                        <div class="col-md-10">
                            <textarea class="form-control" name="deliveryAddress" id="deliveryAddress" rows="2" required>@selectedAddress</textarea>
                        </div>
                    </div>
                    <div class="text-end">
                        <button type="submit" class="btn btn-primary" id="btnCreateOrder">
                            <i class="bi bi-check-circle"></i>
                            Lập đơn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function searchProducts(page) {
        var searchValue = document.getElementById('productSearchValue').value || '';
        var url = '/Order/SearchProducts?searchValue=' + encodeURIComponent(searchValue) + '&page=' + page;
        var container = document.getElementById('productSearchResults');
        container.innerHTML = '<div class="text-center py-3"><span>Đang tải...</span></div>';
        fetch(url)
            .then(function(res) { return res.text(); })
            .then(function(html) {
                container.innerHTML = html;
                container.querySelectorAll('.money-input').forEach(initMoneyInput);
            })
            .catch(function() {
                container.innerHTML = '<div class="text-danger text-center">Không tải được dữ liệu</div>';
            });
    }

    document.getElementById('productSearchValue').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchProducts(1);
        }
    });

    document.getElementById('formCreateOrder').addEventListener('submit', function(e) {
        var customerID = document.getElementById('customerID').value;
        var province = document.getElementById('deliveryProvince').value;
        var address = document.getElementById('deliveryAddress').value.trim();

        if (!customerID || customerID === '0' || !province || !address) {
            e.preventDefault();
            alert('Vui lòng nhập đầy đủ thông tin khách hàng và nơi giao hàng.');
            return false;
        }
    });

    searchProducts(1);
</script>
}
