@model SV22T1020163.Models.Partner.Supplier
@{
    var isUsed = ViewBag.IsUsed as bool? == true;
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger" @(isUsed ? "disabled" : null)>
        <i class="bi bi-trash me-1"></i>
        Xóa
    </button>
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-octagon-fill me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                @if (isUsed)
                {
                    <div class="alert alert-danger d-flex align-items-center">
                        <i class="bi bi-shield-exclamation me-2"></i>
                        Không thể xóa nhà cung cấp này vì đang được sử dụng trong hệ thống.
                    </div>
                }
                else
                {
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa nhà cung cấp sau không?
                    </div>
                }

                <form id="formDelete" asp-action="Delete" asp-route-id="@Model.SupplierID" method="post">
                    <input type="hidden" name="confirm" value="yes" />

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Tên nhà cung cấp</dt>
                        <dd class="col-sm-8">@Model.SupplierName</dd>

                        <dt class="col-sm-4">Tên giao dịch</dt>
                        <dd class="col-sm-8">@Model.ContactName</dd>

                        <dt class="col-sm-4">Điện thoại</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Địa chỉ</dt>
                        <dd class="col-sm-8">@Model.Address</dd>

                        <dt class="col-sm-4">Tỉnh / Thành</dt>
                        <dd class="col-sm-8">@Model.Province</dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>
