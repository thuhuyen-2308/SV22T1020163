@{
    ViewData["Title"] = "Giới thiệu";
}
<div class="about-page">
    <div class="about-band">
        <div class="container py-5">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Giới thiệu</li>
                </ol>
            </nav>
            <div class="row align-items-center g-4">
                <div class="col-lg-7 reveal">
                    <p class="about-band__eyebrow text-uppercase small fw-bold mb-2">Về chúng tôi</p>
                    <h1 class="about-band__title display-6 fw-bold mb-3 font-serif">SmartMini — Tiện ích cho cả gia đình</h1>
                    <p class="about-band__lead text-muted mb-0">Cửa hàng trực tuyến chuyên cung cấp đồ mẹ và bé, đồ gia dụng, mỹ phẩm và các mặt hàng tiện lợi chính hãng.</p>
                </div>
                <div class="col-lg-5 d-none d-lg-flex justify-content-lg-end reveal">
                    @* Đổi icon quyển sách thành icon giỏ hàng/túi xách cho hợp lý *@
                    <div class="about-band__badge-icon" aria-hidden="true"><i class="bi bi-bag-heart-fill"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-4 g-lg-5 align-items-start">
            <div class="col-lg-7 reveal">
                <h2 class="h4 fw-bold mb-3">Câu chuyện của chúng tôi</h2>
                <p class="text-muted"><strong class="text-dark">SmartMini</strong> được hình thành từ mong muốn mang đến những sản phẩm chất lượng, tiện lợi cho cuộc sống hiện đại — chăm sóc gia đình bạn từ những điều nhỏ nhất.</p>
                <p class="text-muted mb-0">Chúng tôi chọn lọc kỹ lưỡng từng mặt hàng, làm việc trực tiếp với các nhà cung cấp uy tín, cam kết thông tin sản phẩm trung thực và hỗ trợ tư vấn tận tâm để bạn chọn được món đồ ưng ý nhất.</p>
            </div>
            <div class="col-lg-5 reveal">
                <div class="about-values card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h3 class="h6 text-uppercase text-muted mb-3">Giá trị cốt lõi</h3>
                        <ul class="list-unstyled mb-0 about-values__list">
                            <li class="d-flex gap-3 mb-3">
                                <span class="about-values__dot"><i class="bi bi-patch-check"></i></span>
                                <span><strong class="d-block">Sản phẩm chính hãng</strong><span class="text-muted small">Ưu tiên nguồn hàng rõ ràng, kiểm định chất lượng minh bạch.</span></span>
                            </li>
                            <li class="d-flex gap-3 mb-3">
                                <span class="about-values__dot"><i class="bi bi-truck"></i></span>
                                <span><strong class="d-block">Giao hàng cẩn thận</strong><span class="text-muted small">Đóng gói chuyên nghiệp, chống va đập — giao hàng nhanh toàn quốc.</span></span>
                            </li>
                            <li class="d-flex gap-3">
                                <span class="about-values__dot"><i class="bi bi-chat-dots"></i></span>
                                <span><strong class="d-block">Tư vấn tận tâm</strong><span class="text-muted small">Gợi ý sản phẩm phù hợp với nhu cầu và ngân sách của bạn.</span></span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mt-2 reveal-stagger">
            <div class="col-md-4">
                <div class="about-pillar text-center p-4 rounded-4 h-100">
                    <i class="bi bi-collection fs-2 text-primary mb-2 d-block"></i>
                    <h3 class="h6 fw-bold">Đa dạng mặt hàng</h3>
                    <p class="text-muted small mb-0">Đồ mẹ và bé, đồ gia dụng, hóa mỹ phẩm và nhiều tiện ích khác.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="about-pillar text-center p-4 rounded-4 h-100">
                    <i class="bi bi-truck fs-2 text-primary mb-2 d-block"></i>
                    <h3 class="h6 fw-bold">Giao hàng tin cậy</h3>
                    <p class="text-muted small mb-0">Theo dõi đơn hàng dễ dàng, thông báo ngay khi chuyển phát.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="about-pillar text-center p-4 rounded-4 h-100">
                    <i class="bi bi-heart fs-2 text-primary mb-2 d-block"></i>
                    <h3 class="h6 fw-bold">Tận tâm phục vụ</h3>
                    <p class="text-muted small mb-0">SmartMini — Đồng hành cùng sự tiện nghi và sức khỏe của gia đình bạn.</p>
                </div>
            </div>
        </div>
    </div>
</div>