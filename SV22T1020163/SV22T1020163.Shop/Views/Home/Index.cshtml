@model PagedResult<Product>
@{
    ViewData["Title"] = "Trang chủ";
    var products = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    // Thay đổi danh sách icon cho phù hợp với đồ gia dụng, mẹ và bé
    string[] icons = { "bi-house-heart", "bi-baby-carriage", "bi-basket", "bi-plug", "bi-magic", "bi-shield-check", "bi-gift", "bi-truck", "bi-heart-pulse", "bi-award" };
}

<section class="home-hero-book mb-0">
    <div class="home-hero-book__mesh" aria-hidden="true"></div>
    <div class="home-hero-book__decor" aria-hidden="true">
        <span class="home-hero-book__blob home-hero-book__blob--a"></span>
        <span class="home-hero-book__blob home-hero-book__blob--b"></span>
        <span class="home-hero-book__blob home-hero-book__blob--c"></span>
        <span class="home-hero-book__spark home-hero-book__spark--1"></span>
        <span class="home-hero-book__spark home-hero-book__spark--2"></span>
        <span class="home-hero-book__spark home-hero-book__spark--3"></span>
    </div>
    <div class="container home-hero-book__inner">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6 order-2 order-lg-1">
                @* Đổi tên thương hiệu *@
                <span class="home-hero-book__badge"><i class="bi bi-bag-heart-fill"></i> Hệ thống SmartMini</span>
                <h1 class="home-hero-book__title">
                    <span class="home-hero-book__title-line">Mọi tiện ích</span>
                    <span class="home-hero-book__title-line home-hero-book__title-line--2"><span class="home-hero-book__accent">cho tổ ấm nhỏ</span></span>
                </h1>
                <p class="home-hero-book__lead">Đồ dùng mẹ và bé, hàng gia dụng thông minh và hóa mỹ phẩm chính hãng — Giao nhanh, giá tốt, tư vấn tận tâm.</p>
                <div class="home-hero-book__actions d-flex flex-wrap gap-2">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-bag-plus me-2"></i>Khám phá sản phẩm
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-primary btn-lg px-4">
                        <i class="bi bi-chat-dots me-2"></i>Tư vấn mua sắm
                    </a>
                </div>
            </div>
            <div class="col-lg-6 order-1 order-lg-2">
                <div class="home-hero-book__showcase reveal">
                    <div class="home-hero-book__showcase-inner">
                        @* Đổi icon thành giỏ hàng *@
                        <i class="bi bi-cart4" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-section--usp py-4 py-lg-5">
    <div class="container">
        <div class="row g-3 g-md-4">
            <div class="col-md-4">
                <div class="home-usp-card reveal">
                    <div class="home-usp-card__icon"><i class="bi bi-patch-check"></i></div>
                    <h3>Hàng chính hãng</h3>
                    <p>Nguồn gốc rõ ràng, kiểm định chất lượng — Ưu tiên các thương hiệu uy tín.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="home-usp-card reveal reveal--delay-1">
                    <div class="home-usp-card__icon"><i class="bi bi-truck"></i></div>
                    <h3>Giao nhanh toàn quốc</h3>
                    <p>Đóng gói cẩn thận, chống va đập — Theo dõi đơn hàng dễ dàng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="home-usp-card reveal reveal--delay-2">
                    <div class="home-usp-card__icon"><i class="bi bi-chat-heart"></i></div>
                    <h3>Tận tâm phục vụ</h3>
                    <p>Hỗ trợ nhiệt tình, tư vấn đúng nhu cầu — Mang lại sự hài lòng tối đa.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-about-snippet py-4 border-top border-bottom" style="border-color: var(--border) !important; background: linear-gradient(180deg, rgba(240,253,250,0.55) 0%, transparent 100%);">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <h2 class="h4 fw-bold mb-2 font-serif">Về SmartMini</h2>
                <p class="text-muted mb-0" style="max-width: 640px;">Chúng tôi tin rằng sự tiện nghi giúp cuộc sống hạnh phúc hơn. SmartMini tuyển chọn những sản phẩm chất lượng nhất — từ đồ dùng cho bé đến thiết bị gia đình — giúp bạn chăm sóc tổ ấm dễ dàng hơn.</p>
            </div>
            <div class="col-lg-5 text-lg-end">
                <a asp-controller="Home" asp-action="About" class="btn btn-outline-primary rounded-pill px-4">Câu chuyện của chúng tôi <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-cat-rail-section py-3">
    <div class="container home-cat-rail-wrap">
        <div class="home-cat-rail reveal-stagger">
            @* Sửa lại các nhãn gợi ý nhanh *@
            <a asp-controller="Product" asp-action="Index" asp-route-search="Mẹ và bé" class="home-cat-rail__chip reveal"><i class="bi bi-baby"></i> Mẹ và bé</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="Gia dụng" class="home-cat-rail__chip reveal"><i class="bi bi-house-door"></i> Gia dụng</a>
            <a asp-controller="Product" asp-action="Index" asp-route-search="Tiện ích" class="home-cat-rail__chip reveal"><i class="bi bi-lightning-charge"></i> Tiện ích</a>
            <a asp-controller="Product" asp-action="Index" class="home-cat-rail__chip reveal"><i class="bi bi-fire"></i> Sản phẩm nổi bật</a>
        </div>
    </div>
</section>

<section class="home-section home-section--cream py-5">
    <div class="container">
        <h2 class="section-title">Vì sao chọn SmartMini</h2>
        <p class="text-muted mb-4" style="max-width: 640px;">Chúng tôi đồng hành cùng gia đình bạn — từ khâu lựa chọn đến trải nghiệm sử dụng hàng ngày.</p>
        <div class="row g-4 home-why-grid">
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal">
                    <div class="home-why-item__icon"><i class="bi bi-people"></i></div>
                    <h3 class="h6 fw-bold">Đội ngũ chuyên nghiệp</h3>
                    <p class="small text-muted mb-0">Hỗ trợ khách hàng nhanh chóng qua hotline &amp; chat — hiểu rõ nhu cầu gia đình.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal reveal--delay-1">
                    <div class="home-why-item__icon"><i class="bi bi-box-seam"></i></div>
                    <h3 class="h6 fw-bold">Kiểm tra kỹ lưỡng</h3>
                    <p class="small text-muted mb-0">Sản phẩm được test kỹ, đóng gói chống sốc trước khi giao đi.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal reveal--delay-2">
                    <div class="home-why-item__icon"><i class="bi bi-arrow-repeat"></i></div>
                    <h3 class="h6 fw-bold">Hậu mãi chu đáo</h3>
                    <p class="small text-muted mb-0">Bảo hành chính hãng, đổi trả linh hoạt — hướng dẫn sử dụng chi tiết.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="home-why-item reveal reveal--delay-3">
                    <div class="home-why-item__icon"><i class="bi bi-geo-alt"></i></div>
                    <h3 class="h6 fw-bold">Mạng lưới giao hàng</h3>
                    <p class="small text-muted mb-0">Hợp tác với các đơn vị vận chuyển uy tín nhất hiện nay.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container py-4">
    @if (categories.Any())
    {
        <section class="home-section home-section--categories mb-5 pt-2">
            <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
                <div>
                    <h2 class="section-title mb-1">Danh mục nổi bật</h2>
                    <p class="text-muted small mb-0">Khám phá theo nhóm hàng — cập nhật mẫu mã mới thường xuyên.</p>
                </div>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill">
                    Tất cả sản phẩm <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="home-category-grid row g-3 g-md-4 reveal-stagger">
                @for (int i = 0; i < categories.Count && i < 6; i++)
                {
                    var cat = categories[i];
                    <div class="col-6 col-sm-4 col-md-3 col-xl-2">
                        <a class="category-card category-card--home d-flex flex-column align-items-center justify-content-center h-100 reveal text-decoration-none" asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.CategoryID">
                            <span class="category-card--home__icon-wrap">
                                <i class="bi @icons[i % icons.Length]" aria-hidden="true"></i>
                            </span>
                            <h6 class="category-card--home__title mb-0">@cat.CategoryName</h6>
                        </a>
                    </div>
                }
            </div>
        </section>
    }

    <section class="home-section mb-5">
        <h2 class="section-title">Gợi ý cho gia đình</h2>
        <p class="text-muted mb-4" style="max-width: 560px;">Sản phẩm thiết yếu — bấm để xem danh sách gợi ý.</p>
        <div class="row g-3 g-lg-4">
            <div class="col-md-4">
                <a asp-controller="Product" asp-action="Index" asp-route-search="mẹ bé" class="home-inspire-card home-inspire-card--a reveal d-flex flex-column justify-content-end">
                    <span class="home-inspire-card__label">An toàn</span>
                    <h3>Đồ dùng Mẹ &amp; Bé</h3>
                    <p>Bình sữa, tã bỉm, thực phẩm dinh dưỡng tốt nhất cho bé yêu.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Product" asp-action="Index" asp-route-search="gia dụng" class="home-inspire-card home-inspire-card--b reveal reveal--delay-1 d-flex flex-column justify-content-end">
                    <span class="home-inspire-card__label">Tiện lợi</span>
                    <h3>Gia dụng thông minh</h3>
                    <p>Đồ bếp, thiết bị vệ sinh giúp tối ưu thời gian làm việc nhà.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Product" asp-action="Index" asp-route-search="mỹ phẩm" class="home-inspire-card home-inspire-card--c reveal reveal--delay-2 d-flex flex-column justify-content-end">
                    <span class="home-inspire-card__label">Sức khỏe</span>
                    <h3>Hóa mỹ phẩm</h3>
                    <p>Sữa tắm, dầu gội, nước giặt xả — chăm sóc cả gia đình.</p>
                </a>
            </div>
        </div>
    </section>

    <section class="home-section mb-5">
        <div class="row g-3 reveal-stagger">
            <div class="col-lg-6">
                <div class="reveal h-100">
                    <a asp-controller="Product" asp-action="Index" class="home-mid-banner home-mid-banner--run d-block text-decoration-none h-100">
                        <div class="home-mid-banner__content">
                            <span class="small text-uppercase opacity-75">Sản phẩm hot</span>
                            <h3 class="fw-bold mb-2 mt-1">Bảng xếp hạng bán chạy</h3>
                            <p class="mb-3 small">Top những mặt hàng được săn đón nhất trong tuần</p>
                            <span class="btn btn-sm fw-semibold rounded-pill">Xem ngay <i class="bi bi-arrow-right ms-1"></i></span>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="reveal h-100">
                    <a asp-controller="Account" asp-action="Register" class="home-mid-banner home-mid-banner--court d-block text-decoration-none h-100">
                        <div class="home-mid-banner__content">
                            <span class="small text-uppercase">Thành viên</span>
                            <h3 class="fw-bold mb-2 mt-1">Đăng ký nhận ưu đãi</h3>
                            <p class="mb-3 small">Nhận ngay voucher giảm giá cho đơn hàng đầu tiên</p>
                            <span class="btn btn-sm fw-semibold rounded-pill">Đăng ký miễn phí <i class="bi bi-arrow-right ms-1"></i></span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section mb-5">
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <div>
                <h2 class="section-title mb-1">Được xem nhiều nhất</h2>
                <p class="text-muted small mb-0">Các sản phẩm đang nhận được sự quan tâm lớn.</p>
            </div>
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>
        @if (products.Any())
        {
            <div class="row g-3 reveal-stagger">
                @foreach (var p in products)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="product-card reveal h-100">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductID">
                                <div class="card-img-wrap">
                                    <img src="@(string.IsNullOrEmpty(p.Photo) ? "/anh_chung/products/noproduct.svg" : "/anh_chung/products/" + p.Photo)"
                                         alt="@p.ProductName" />
                                </div>
                            </a>
                            <div class="card-body">
                                <a class="product-name" asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductID">@p.ProductName</a>
                                <div class="product-price">@p.Price.ToString("N0") đ</div>
                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    <input type="hidden" name="productId" value="@p.ProductID" />
                                    <button type="submit" class="btn btn-add-cart w-100">
                                        <i class="bi bi-cart-plus me-1"></i>Thêm vào giỏ
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 px-3 rounded-4 border border-dashed" style="border-color: var(--border) !important; background: var(--surface);">
                <i class="bi bi-inboxes fs-1 text-muted mb-2 d-block"></i>
                <p class="text-muted mb-3 mb-md-0">Chưa có sản phẩm nổi bật. Vui lòng quay lại sau nhé.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-3">Đến cửa hàng</a>
            </div>
        }
    </section>

    <section class="home-section home-section--cream py-4 rounded-4 mb-4 px-3 px-md-4">
        <h2 class="section-title">Mẹo mua sắm thông minh</h2>
        <p class="text-muted mb-3">Gợi ý từ SmartMini — Luôn kiểm tra thông số và đánh giá sản phẩm.</p>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="p-3 rounded-3 border bg-white h-100">
                    <h3 class="h6 fw-bold text-primary">Dành cho Mẹ</h3>
                    <p class="small text-muted mb-0">Nên chọn các chất liệu an toàn, BPA Free cho bình sữa và đồ chơi của bé.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-3 border bg-white h-100">
                    <h3 class="h6 fw-bold text-primary">Đồ gia dụng</h3>
                    <p class="small text-muted mb-0">Ưu tiên các sản phẩm tiết kiệm điện và có tích hợp nhiều tính năng thông minh.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 rounded-3 border bg-white h-100">
                    <h3 class="h6 fw-bold text-primary">Săn Sale</h3>
                    <p class="small text-muted mb-0">Theo dõi trang fanpage hoặc đăng ký email để nhận thông báo khuyến mãi sớm nhất.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section mb-5">
        <h2 class="section-title">Câu hỏi thường gặp</h2>
        <div class="accordion accordion-flush home-faq rounded-4 border overflow-hidden" id="faqHome">
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">Sản phẩm có chính hãng không?</button>
                </h3>
                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqHome">
                    <div class="accordion-body text-muted small">Tất cả sản phẩm tại SmartMini đều có nguồn gốc rõ ràng và cam kết chính hãng 100%.</div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">Thời gian giao hàng?</button>
                </h3>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqHome">
                    <div class="accordion-body text-muted small">Thời gian giao hàng từ 1-3 ngày (nội thành) và 3-5 ngày đối với các tỉnh thành khác.</div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">Chính sách đổi trả?</button>
                </h3>
                <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqHome">
                    <div class="accordion-body text-muted small">Chúng tôi hỗ trợ đổi trả trong vòng 7 ngày nếu sản phẩm có lỗi từ nhà sản xuất hoặc bị hư hỏng do vận chuyển.</div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-section--cream py-5 rounded-4 mb-4 px-3 px-md-4">
        <div class="container-fluid px-0">
            <h2 class="section-title">Quy trình mua hàng</h2>
            <p class="text-muted mb-4">Mua sắm đơn giản cùng SmartMini.</p>
            <div class="home-steps">
                <div class="home-step reveal">
                    <span class="home-step__num">1</span>
                    <div>
                        <h4>Chọn mua</h4>
                        <p>Thêm sản phẩm vào giỏ hàng và điền thông tin.</p>
                    </div>
                </div>
                <div class="home-step reveal reveal--delay-1">
                    <span class="home-step__num">2</span>
                    <div>
                        <h4>Xác nhận</h4>
                        <p>Chúng tôi sẽ gọi xác nhận và bắt đầu đóng gói hàng.</p>
                    </div>
                </div>
                <div class="home-step reveal reveal--delay-2">
                    <span class="home-step__num">3</span>
                    <div>
                        <h4>Nhận hàng</h4>
                        <p>Kiểm tra hàng hóa và hoàn tất thanh toán (COD).</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-bottom-cta text-center rounded-4 overflow-hidden mb-2 reveal">
        <div class="home-bottom-cta__inner py-5 px-3">
            <h3 class="fw-bold mb-2 font-serif">Nâng tầm cuộc sống cùng SmartMini</h3>
            <p class="mb-4 text-muted-cta mx-auto" style="max-width:520px;">Sản phẩm chất lượng — Giá cả cạnh tranh — Phục vụ từ tâm</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg fw-semibold px-5">
                <i class="bi bi-bag-heart me-2"></i>Mua sắm ngay
            </a>
        </div>
    </section>
</div>