@{
    ViewData["Title"] = "Liên hệ";
}

<div class="contact-page">
    <div class="contact-band">
        <div class="container py-5">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Liên hệ</li>
                </ol>
            </nav>
            <div class="row align-items-center g-4">
                <div class="col-lg-7 reveal">
                    <p class="contact-band__eyebrow text-uppercase small fw-bold mb-2">Liên hệ</p>
                    <h1 class="contact-band__title display-6 fw-bold mb-3">Chúng tôi luôn sẵn sàng hỗ trợ</h1>
                    <p class="contact-band__lead text-muted mb-0">Tư vấn, đặt hàng và lịch giao — gọi điện, email hoặc để lại tin nhắn bên dưới.</p>
                </div>
                <div class="col-lg-5 d-none d-lg-flex justify-content-lg-end reveal">
                    <div class="contact-band__badge-icon" aria-hidden="true"><i class="bi bi-envelope-paper-heart"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-4 g-lg-5 align-items-stretch">
            <div class="col-lg-7 reveal">
                <div class="card border-0 shadow-sm h-100 contact-form-card">
                    <div class="card-body p-4">
                        <h2 class="h4 fw-bold mb-2">Gửi tin nhắn</h2>
                        <p class="text-muted small mb-4">Điền form — chúng tôi phản hồi trong giờ làm việc.</p>
                        <form>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Họ tên</label>
                                <input type="text" class="form-control form-control-lg rounded-3" placeholder="Nhập họ tên" autocomplete="name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Email</label>
                                <input type="email" class="form-control form-control-lg rounded-3" placeholder="Nhập email" autocomplete="email" />
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold">Nội dung</label>
                                <textarea class="form-control rounded-3" rows="5" placeholder="Nội dung tin nhắn..."></textarea>
                            </div>
                            <button type="button" class="btn btn-primary btn-lg rounded-pill px-4" onclick="alert('Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi sớm nhất.')">
                                <i class="bi bi-send me-2"></i>Gửi tin nhắn
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 reveal">
                <div class="about-values card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h3 class="h6 text-uppercase text-muted mb-3">Thông tin liên hệ</h3>
                        <ul class="list-unstyled mb-0 about-values__list">
                            <li class="d-flex gap-3 mb-3">
                                <span class="about-values__dot"><i class="bi bi-geo-alt-fill"></i></span>
                                <span>
                                    <strong class="d-block">Địa chỉ</strong>
                                    <span class="text-muted small">77 Nguyễn Huệ, TP Huế</span>
                                </span>
                            </li>
                            <li class="d-flex gap-3 mb-3">
                                <span class="about-values__dot"><i class="bi bi-telephone-fill"></i></span>
                                <span>
                                    <strong class="d-block">Điện thoại</strong>
                                    <span class="text-muted small">0799486338</span>
                                </span>
                            </li>
                            <li class="d-flex gap-3 mb-3">
                                <span class="about-values__dot"><i class="bi bi-envelope-fill"></i></span>
                                <span>
                                    <strong class="d-block">Email</strong>
                                    <span class="text-muted small">support@thuhuyenmart.vn</span>
                                </span>
                            </li>
                            <li class="d-flex gap-3">
                                <span class="about-values__dot"><i class="bi bi-clock-fill"></i></span>
                                <span>
                                    <strong class="d-block">Giờ làm việc</strong>
                                    <span class="text-muted small">Thứ 2 - Thứ 7: 8:00 - 21:00<br />Chủ nhật: 9:00 - 18:00</span>
                                </span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
