@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-page" aria-label="Đăng nhập">
    <div class="container container-narrow">
        <div class="auth-card auth-card--elevated">
            <div class="auth-card__head text-center">
                <div class="auth-card__icon"><i class="bi bi-person-circle" aria-hidden="true"></i></div>
                <h2 class="auth-card__title mb-1">Đăng nhập</h2>
                <p class="auth-card__sub text-muted small mb-0">Chào bạn — đăng nhập để mua sắm và theo dõi đơn hàng.</p>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 mt-3"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 mt-3"><i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error</div>
            }

            <form method="post" asp-action="Login" class="mt-3">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div class="mb-3">
                    <label class="form-label" for="login-email">Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input id="login-email" type="email" name="email" class="form-control" placeholder="Nhập email" required autofocus autocomplete="email" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="login-password">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input id="login-password" type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required autocomplete="current-password" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 mt-1 py-2">Đăng nhập</button>
            </form>

            <p class="text-center mt-4 mb-0 small">
                <span class="text-muted">Chưa có tài khoản?</span>
                <a asp-action="Register" class="auth-card__link">Đăng ký ngay</a>
            </p>
        </div>
    </div>
</section>
