@model SV22T1020163.Models.Sales.OrderViewInfo
@{
    Layout = null;
}
<form method="post" asp-action="Finish" asp-route-id="@Model.OrderID">
    <input type="hidden" name="confirm" value="yes" />
    <div class="modal-header text-bg-success">
        <strong class="modal-title">Xác nhận hoàn tất đơn hàng #@Model.OrderID</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-success d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có chắc chắn xác nhận đơn hàng <b>#@Model.OrderID</b> đã được giao thành công?
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
