@model SV22T1020163.Models.Common.PagedResult<SV22T1020163.Models.Catalog.Product>

@if (Model.DataItems == null || Model.DataItems.Count == 0)
{
    <p class="text-muted text-center py-3">Không tìm thấy mặt hàng nào.</p>
}
else
{
    foreach (var product in Model.DataItems)
    {
        var imgSrc = string.IsNullOrEmpty(product.Photo) ? "/anh_chung/products/noproduct.svg" : "/anh_chung/products/" + product.Photo;
        <form method="post" asp-action="AddToCart" class="border rounded p-2 mb-2">
            <input type="hidden" name="productID" value="@product.ProductID" />
            <strong>@product.ProductName</strong>
            <div class="row mt-2">
                <div class="col-4">
                    <img src="@imgSrc" class="img-fluid border" style="max-height:80px" />
                </div>
                <div class="col-8">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label mb-0">Giá</label>
                            <input class="form-control form-control-sm money-input"
                                   name="salePrice"
                                   value="@product.Price.ToString("0")" />
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-0">SL</label>
                            <input type="number" name="quantity"
                                   min="1" value="1"
                                   class="form-control form-control-sm" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                        <i class="bi bi-cart-plus"></i>
                        Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
    }

    @if (Model.PageCount > 1)
    {
        <nav class="mt-2">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:void(0)" onclick="searchProducts(@(Model.Page - 1))">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@Model.Page / @Model.PageCount</span>
                </li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:void(0)" onclick="searchProducts(@(Model.Page + 1))">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
