@model SV22T1020163.Models.Catalog.Product
@{
    ViewBag.Title = "Xóa mặt hàng";
    var isUsed = ViewBag.IsUsed as bool? == true;
    var photoSrc = string.IsNullOrEmpty(Model.Photo) ? "/anh_chung/products/noproduct.svg" : "/anh_chung/products/" + Model.Photo;
}

@section PageToolBar {
    @if (!isUsed)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" asp-action="Delete" asp-route-id="@Model.ProductID" method="post">
                    <input type="hidden" name="confirm" value="yes" />

                    @if (isUsed)
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-x-octagon me-2"></i>
                            Không thể xóa mặt hàng này.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa mặt hàng sau không?
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Tên mặt hàng</dt>
                                <dd class="col-sm-8">@Model.ProductName</dd>

                                <dt class="col-sm-4">Đơn vị tính</dt>
                                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Unit) ? "—" : Model.Unit)</dd>

                                <dt class="col-sm-4">Giá bán</dt>
                                <dd class="col-sm-8 text-danger fw-bold">@Model.Price.ToString("N0") đ</dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsSelling)
                                    {
                                        <span class="badge bg-success">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ngừng bán</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">Mô tả</dt>
                                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ProductDescription) ? "—" : Model.ProductDescription)</dd>
                            </dl>
                        </div>

                        <div class="col-md-4 text-center">
                            <img src="@photoSrc"
                                 class="img-fluid img-thumbnail"
                                 alt="@Model.ProductName"
                                 style="max-height: 220px;" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
