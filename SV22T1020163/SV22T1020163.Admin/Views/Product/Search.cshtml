@model SV22T1020163.Models.Common.PagedResult<SV22T1020163.Models.Catalog.Product>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng.
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Đơn vị</th>
                    <th style="width:120px;">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:140px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? "/anh_chung/products/noproduct.svg" : "/anh_chung/products/" + item.Photo)" 
                                 class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.ProductName" />
                        </td>
                        <td>
                            <strong>@item.ProductName</strong><br />
                            <small class="text-muted">@item.ProductDescription</small>
                        </td>
                        <td>@item.Unit</td>
                        <td class="text-end text-danger">@item.Price.ToString("N0")</td>
                        <td class="text-center">
                            @if (item.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Hết hàng</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            @if (User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.Manager))
                            {
                                <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                            else
                            {
                                <a href="~/Product/Detail/@item.ProductID" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        @if (Model.PageCount > 1)
        {
            <nav>
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page - 1))">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @foreach (var p in Model.GetDisplayPages())
                    {
                        if (p.Page == 0)
                        {
                            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                        }
                        else if (p.IsCurrent)
                        {
                            <li class="page-item active"><span class="page-link">@p.Page</span></li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:;" onclick="doSearch(@p.Page)">@p.Page</a>
                            </li>
                        }
                    }
                    <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page + 1))">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
