@model SV22T1020163.Models.Catalog.Category
@{
    ViewBag.Title = "Xóa loại hàng";
    var isUsed = ViewBag.IsUsed as bool? == true;
}

@section PageToolBar {
    @if (!isUsed)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa loại hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" asp-action="Delete" asp-route-id="@Model.CategoryID" method="post">
                    <input type="hidden" name="confirm" value="yes" />

                    @if (isUsed)
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-x-octagon me-2"></i>
                            Không thể xóa loại hàng này vì đang được sử dụng trong hệ thống.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa loại hàng sau không?
                        </div>
                    }

                    <dl class="row mb-0">
                        <dt class="col-sm-3">Tên loại hàng</dt>
                        <dd class="col-sm-9">@Model.CategoryName</dd>

                        <dt class="col-sm-3">Mô tả</dt>
                        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>
