@model SV22T1020163.Models.Partner.Customer
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2"></i>
                    Thông tin khách hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" asp-action="Edit" method="post">
                    <input type="hidden" asp-for="CustomerID" />

                    <div class="row align-items-end">
                        <div class="col-md-5 mb-3">
                            <label asp-for="CustomerName" class="form-label">Tên khách hàng: <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="CustomerName" placeholder="Nhập tên khách hàng" autofocus />
                            @Html.ValidationMessageFor(m => m.CustomerName, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-5 mb-3">
                            <label asp-for="ContactName" class="form-label">Tên giao dịch: <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="ContactName" placeholder="Nhập tên giao dịch" />
                            @Html.ValidationMessageFor(m => m.ContactName, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsLocked" />
                                <label class="form-check-label" asp-for="IsLocked">
                                    Khóa tài khoản
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label asp-for="Phone" class="form-label">Điện thoại:</label>
                            <input type="tel" class="form-control" asp-for="Phone" placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-7 mb-3">
                            <label asp-for="Email" class="form-label">Email: <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" asp-for="Email" placeholder="Nhập email" />
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Địa chỉ:</label>
                        <textarea class="form-control" asp-for="Address" rows="3" placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Province" class="form-label">Tỉnh / Thành: <span class="text-danger">*</span></label>
                        <select class="form-select" asp-for="Province">
                            <option value="">-- Chọn tỉnh / thành --</option>
                            @foreach (var item in ViewBag.Provinces)
                            {
                                <option value="@item.ProvinceName">@item.ProvinceName</option>
                            }
                        </select>
                        @Html.ValidationMessageFor(m => m.Province, "", new { @class = "text-danger" })
                    </div>

                    <div class="text-danger">
                        @Html.ValidationSummary(true)
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
