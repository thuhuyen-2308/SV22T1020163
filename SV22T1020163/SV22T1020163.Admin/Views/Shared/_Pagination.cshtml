@model (int Page, int PageCount, List<SV22T1020163.Models.Common.PageItem> DisplayPages, string FormId)
@if (Model.PageCount > 1)
{
    <nav>
        <ul class="pagination pagination-sm justify-content-center mb-0">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('@Model.FormId'), @(Model.Page - 1))">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @foreach (var p in Model.DisplayPages)
            {
                if (p.Page == 0)
                {
                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                }
                else if (p.IsCurrent)
                {
                    <li class="page-item active"><span class="page-link">@p.Page</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('@Model.FormId'), @p.Page)">@p.Page</a>
                    </li>
                }
            }

            <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('@Model.FormId'), @(Model.Page + 1))">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}
