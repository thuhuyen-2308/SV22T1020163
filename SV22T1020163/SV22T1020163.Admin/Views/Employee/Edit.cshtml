@model SV22T1020163.Models.HR.Employee
@{
    var isCreate = (Model.EmployeeID == 0);
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    @(isCreate ? "Thêm mới nhân viên" : "Cập nhật nhân viên")
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post"
                      asp-action="@(isCreate ? "Create" : "Edit")"
                      enctype="multipart/form-data">

                    <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Họ và tên</label>
                        <div class="col-sm-5">
                            <input type="text"
                                   name="FullName"
                                   class="form-control"
                                   value="@Model.FullName"
                                   placeholder="Nhập họ và tên" autofocus />
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input type="text"
                                   name="BirthDate"
                                   class="form-control date-picker"
                                   value="@(Model.BirthDate?.ToString("dd/MM/yyyy"))" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea name="Address"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Nhập địa chỉ">@Model.Address</textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-2">
                            <input type="tel"
                                   name="Phone"
                                   class="form-control"
                                   value="@Model.Phone"
                                   placeholder="Nhập số điện thoại" />
                        </div>
                        <label class="col-sm-1 col-form-label text-end">Email</label>
                        <div class="col-sm-6">
                            <input type="email"
                                   name="Email"
                                   class="form-control"
                                   value="@Model.Email"
                                   placeholder="Nhập email" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />
                            <div class="mt-2">
                                @if (!string.IsNullOrEmpty(Model.Photo))
                                {
                                    <img id="imgPreview"
                                         src="~/anh_chung/employees/@Model.Photo"
                                         class="img-thumbnail"
                                         style="max-height: 150px;" />
                                }
                                else
                                {
                                    <img id="imgPreview"
                                         src="~/anh_chung/employees/nophoto.png"
                                         class="img-thumbnail"
                                         style="max-height: 150px;" />
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsWorking"
                                       id="IsWorking"
                                       value="true"
                                       @(Model.IsWorking == true ? "checked" : "") />
                                <label class="form-check-label" for="IsWorking">
                                    Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
