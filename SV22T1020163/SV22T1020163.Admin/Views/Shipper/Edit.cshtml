@model SV22T1020163.Models.Partner.Shipper
@{
    var isCreate = Model.ShipperID == 0;
    ViewData["Title"] = isCreate ? "Thêm người giao hàng" : "Cập nhật người giao hàng";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bicycle me-2"></i>
                    @(isCreate ? "Thêm mới người giao hàng" : "Thông tin người giao hàng")
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="@(isCreate ? "Create" : "Edit")">
                    <input type="hidden" asp-for="ShipperID" />

                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="mb-3">
                        <label asp-for="ShipperName" class="form-label">Tên người giao hàng <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" asp-for="ShipperName" placeholder="Nhập tên người giao hàng" autofocus />
                        <span asp-validation-for="ShipperName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Điện thoại</label>
                        <input type="tel" class="form-control" asp-for="Phone" placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
