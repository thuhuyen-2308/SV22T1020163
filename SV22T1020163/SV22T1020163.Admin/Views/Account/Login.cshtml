@{
    ViewBag.Title = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartMini Admin — Đăng nhập</title>
    <link rel="icon" type="image/svg+xml" href="~/anh_chung/gh.jpg" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Literata:opsz,wght@7..72,600;7..72,700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
    <link rel="stylesheet" href="@Url.Content("~/css/site.css")" asp-append-version="true" />
</head>
<body class="login-page login-page--thb">
    <div class="login-page__mesh" aria-hidden="true"></div>
    <div class="login-page__glow login-page__glow--1" aria-hidden="true"></div>
    <div class="login-page__glow login-page__glow--2" aria-hidden="true"></div>
    <div class="login-page__pattern" aria-hidden="true"></div>

    <main class="login-thb-main">
        <div class="login-thb-card card border-0 shadow-lg">
            <div class="card-body login-thb-card__body p-4 p-sm-5">
                <div class="text-center mb-4">
                    <a href="/" class="login-thb-brand d-inline-block text-decoration-none" title="SmartMini Admin">
                        <img src="~/anh_chung/gh.jpg" class="login-thb-brand__logo" width="260" height="48" alt="SmartMini" asp-append-version="true" />
                    </a>
                    <p class="login-thb-card__subtitle text-muted small mt-3 mb-0">Hệ thống quản trị sản phẩm</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 py-2 small mb-3">
                        @Html.ValidationSummary(true)
                    </div>
                }

                <form asp-action="Login" asp-controller="Account" method="post" class="login-thb-form">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-secondary">Email</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text login-thb-input-icon"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="email" class="form-control login-thb-input" placeholder="you@company.com" autocomplete="username" autofocus />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-semibold text-secondary">Mật khẩu</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text login-thb-input-icon"><i class="bi bi-lock-fill"></i></span>
                            <input type="password" name="password" class="form-control login-thb-input" placeholder="••••••••" autocomplete="current-password" />
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-lg login-thb-submit text-white fw-semibold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <p class="login-thb-footer text-center small mt-4 mb-0">© @DateTime.Now.Year SmartMini · Admin</p>
    </main>

    <script src="~/lib/bootstrap/bootstrap.bundle.min.js"></script>
</body>
</html>
